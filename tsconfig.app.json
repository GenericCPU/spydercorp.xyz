{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@aeon-ui/core": ["../../../../AeonUI/packages/core/dist/index.d.ts"],
      "@aeon-ui/primitives": ["../../../../AeonUI/packages/primitives/dist/index.d.ts"],
      "@aeon-ui/react": ["../../../../AeonUI/packages/react/dist/index.d.ts"]
    }
  },
  "include": ["src"]
}
